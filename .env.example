# ============================================================================
# RICD — Environment configuration
# ============================================================================
# HOW TO USE
#   1. Copy this file to `.env` (same folder, next to requirements.txt):
#        copy .env.example .env
#   2. Edit the values below.
#   3. Restart the server (settings are read at startup).
#
# `.env` is git-ignored — secrets never get committed. Real OS environment
# variables always override anything in this file.
# ============================================================================


# ---------------------------------------------------------------------------
# DEBUG — set to False for production.
#   True  = developer mode: detailed error pages, relaxed security.
#   False = production mode: generic error pages, security hardening on
#           (secure cookies, HSTS). Requires a real DJANGO_SECRET_KEY.
# ---------------------------------------------------------------------------
DJANGO_DEBUG=True


# ---------------------------------------------------------------------------
# SECRET_KEY — cryptographic signing key (sessions, CSRF, password resets).
#   REQUIRED when DJANGO_DEBUG=False (the app refuses to start without it).
#   Must be long (50+ chars), random, and kept secret.
#   Generate one with:
#     python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# ---------------------------------------------------------------------------
#DJANGO_SECRET_KEY=paste-a-long-random-generated-key-here


# ---------------------------------------------------------------------------
# ALLOWED_HOSTS — comma-separated hostnames the site may be served from.
#   Add your production domain(s) and/or server IP.
# ---------------------------------------------------------------------------
#DJANGO_ALLOWED_HOSTS=ricd.example.qld.gov.au,localhost,127.0.0.1


# ---------------------------------------------------------------------------
# DATABASE — which database engine to use.
#   DB_ENGINE options:
#     sqlite3     = file database (db.sqlite3 in src/). Fine for development
#                   and small single-user trials. No other DB_* fields needed.
#     postgresql  = production database. Fill in ALL the DB_* fields below.
#   If DB_ENGINE is not set: DEBUG=True uses sqlite3, DEBUG=False uses postgresql.
# ---------------------------------------------------------------------------
DB_ENGINE=sqlite3

# --- PostgreSQL connection (only used when DB_ENGINE=postgresql) -----------
# DB_HOST     = server address ("link"): hostname or IP of the PostgreSQL server,
#               e.g. localhost or db.internal.qld.gov.au
# DB_PORT     = PostgreSQL port (default 5432)
# DB_NAME     = the database name on that server (created with CREATE DATABASE)
# DB_USER     = PostgreSQL username with rights to that database
# DB_PASSWORD = that user's password
#
# After switching, run the migrations against the new database:
#     cd src && python manage.py migrate && python manage.py createsuperuser
#DB_HOST=localhost
#DB_PORT=5432
#DB_NAME=ricdapp
#DB_USER=ricdapp
#DB_PASSWORD=change-me


# ---------------------------------------------------------------------------
# EMAIL / SMTP — configured in the APP, not in this file.
#   Email is managed at:  Maintenance -> Email Settings  (Manager login)
#   There you set: SMTP host, port, TLS, username, password, from-address,
#   send mode (Log only vs SMTP), and the master "notifications enabled"
#   on/off switch — no restart needed, and it can be changed by managers
#   without server access. Nothing to configure here.
# ---------------------------------------------------------------------------


# ---------------------------------------------------------------------------
# Optional: logging verbosity (DEBUG, INFO, WARNING, ERROR). Default INFO.
# ---------------------------------------------------------------------------
#DJANGO_LOG_LEVEL=INFO
